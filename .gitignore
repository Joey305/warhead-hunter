# ------------------------------------------------------------
# Runtime / generated data
# ------------------------------------------------------------

# Ignore all generated jobs by default.
# Curated public demo jobs are explicitly unignored below.
jobs/*
!jobs/.gitkeep

# Uploads are runtime data
uploads/*
!uploads/.gitkeep


# ------------------------------------------------------------
# Python cache / build artifacts
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
build/
dist/


# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------

.venv/
venv/
env/
ENV/


# ------------------------------------------------------------
# Logs / temp / cache
# ------------------------------------------------------------

*.log
*.tmp
tmp/
temp/
.cache/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/


# ------------------------------------------------------------
# Local / backup / experimental folders
# ------------------------------------------------------------

Q0dex/
Qodex.summary.md
ORIGINAL/
RESTORE_BACKUP*/
experimental_broken_attempts/


# ------------------------------------------------------------
# Secrets / local config
# ------------------------------------------------------------

.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
credentials*.json
token*.json
secrets*.json


# ------------------------------------------------------------
# OS / editor
# ------------------------------------------------------------

.DS_Store
.vscode/
.idea/


# ------------------------------------------------------------
# Large scientific / output files
# These are ignored globally, but curated jobs below are unignored
# afterward so their required artifacts can still be committed.
# ------------------------------------------------------------

*.xtc
*.trr
*.dcd
*.nc
*.gro
*.tpr
*.edr
*.cpt
*.xvg
*.pdbqt
*.zip
*.tar
*.tar.gz
*.gz


# ------------------------------------------------------------
# Warhead Hunter curated / public demo jobs
# These are the four example jobs shown on the API docs page.
# ------------------------------------------------------------

!jobs/b281996d/
!jobs/b281996d/**

!jobs/032917e1/
!jobs/032917e1/**

!jobs/d750cfea/
!jobs/d750cfea/**

!jobs/d6706e03/
!jobs/d6706e03/**


# ------------------------------------------------------------
# Never commit transient junk inside jobs
# These rules come after the curated-job exceptions on purpose.
# ------------------------------------------------------------

jobs/**/__pycache__/
jobs/**/*.pyc
jobs/**/.DS_Store